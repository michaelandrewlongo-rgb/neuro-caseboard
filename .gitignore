__pycache__/
*.pyc
*.egg-info/
.eggs/
# repo-root Python build artifact only — anchored with a leading slash so the
# pattern does not also swallow nested dirs like web/src/components/build/
# (the unanchored form silently kept those out of git and broke the web build).
/build/
dist/
.pytest_cache/
.venv/
venv/
# throwaway venvs created by ci/local-ci.sh and the package job
.local-ci-venv/
.local-ci-pkgvenv/
.ci-venv/
*.pdf
!tests/**/*.pdf
out/
/tmp/
.DS_Store
eval/_outputs/
# regenerable generated-schematic render artifacts (WS-4 eval)
eval/_fig_specs/
# local secrets / environment — never commit (keep .env.example tracked)
.env
.env.*
!.env.example
# GUI council capture artifacts (regenerable)
gui-council/shots/
gui-council/axe/
# local throwaway venvs
.testvenv/
.project-loop/
