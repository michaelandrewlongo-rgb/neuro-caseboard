# Local environment for the neuro-caseboard engine. Copy to .env and fill in real values.
# .env is gitignored and auto-loaded by neuro_caseboard.literature.config (no python-dotenv needed).
# Real env vars always win over this file.

# PubMed / NCBI E-utilities API key (raises the rate limit from 3 to 10 req/s).
# Get one at: https://www.ncbi.nlm.nih.gov/account/  -> Settings -> API Key Management
NCBI_API_KEY=
# Optional fallback key (used only if NCBI_API_KEY is empty).
NCBI_API_KEY_2=

# LLM synthesis. The default provider is OpenRouter with glm-5.2 for synthesis (highest
# blind-graded answer quality) and a separate fast model for query disambiguation. Both need
# an OpenRouter key (https://openrouter.ai/keys). To use Vertex Gemini instead (free on GCP
# credit), set SYNTH_PROVIDER=vertex and provide GOOGLE_CLOUD_PROJECT + ADC.
OPENROUTER_API_KEY=
# Defaults (override only to change models): SYNTH_PROVIDER=openrouter,
# OPENROUTER_MODEL=z-ai/glm-5.2, ANALYZE_MODEL=google/gemini-3.1-flash-lite.
# OPENROUTER_MODEL=
# ANALYZE_MODEL=
# SYNTH_PROVIDER=
