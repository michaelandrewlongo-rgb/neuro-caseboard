{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "neuro-caseboard/evaluation/benchmark-manifest",
  "title": "Benchmark manifest record",
  "description": "One record per benchmark question (JSONL: one object per line).",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "domain", "source_number", "question", "benchmark_version", "enabled"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(NIS|SPINE|TUMOR|GENERAL|OPEN-CV|FUNCTIONAL|TRAUMA)-[0-9]{2}$",
      "description": "Stable per-section ID; numbering restarts each section."
    },
    "domain": {
      "type": "string",
      "enum": [
        "Neurointerventional Surgery",
        "Spine Surgery",
        "Brain Tumor Surgery",
        "General Neurosurgery",
        "Open Cerebrovascular Surgery",
        "Functional Neurosurgery",
        "Trauma Neurosurgery"
      ]
    },
    "source_number": {"type": "integer", "minimum": 1, "maximum": 11},
    "question": {"type": "string", "minLength": 1, "description": "Verbatim question text from the source."},
    "benchmark_version": {"type": "string", "minLength": 1},
    "enabled": {"type": "boolean"}
  }
}
