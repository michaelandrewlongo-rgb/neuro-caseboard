# neuro-caseboard environment — copy to the repo root as `.env` and fill in.
# Loaded by neuro_core/config.py (env vars win over this file win over built-in defaults).
#
# NOTE: data paths are intentionally omitted. setup-mac.sh extracts the index/assets/cards
# to the DEFAULT home locations, which config.py already points at — so on a stock Mac
# install you only need API keys here. Uncomment the path block at the bottom only if you
# put the data somewhere non-default.

# ── LLM Explorer (case-specific question cards) ───────────────────────────────────────────
# Without a key, the pipeline falls back to caseprep's deterministic Explorer (still works).
ANTHROPIC_API_KEY=
# CASEBOARD_LLM=1                      # set 0 to force the deterministic path
# CASEBOARD_LLM_MODEL=claude-opus-4-8

# ── Answer synthesis backend ──────────────────────────────────────────────────────────────
# Default provider is Vertex AI (your GCP free credits). After setting the project, run:
#   gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# VERTEX_MODEL=gemini-2.5-pro
# SYNTH_PROVIDER=vertex

# ── Contemporary Literature (PubMed) lane ─────────────────────────────────────────────────
# Optional; raises the E-utilities rate limit. Lane is on by default without a key.
NCBI_API_KEY=
# LITERATURE_RETRIEVAL=1
# LITERATURE_RECENCY_YEARS=7

# ── Web app gate (Streamlit) ──────────────────────────────────────────────────────────────
# Set to require a passcode before the app loads. Leave blank for no gate (fine locally).
APP_PASSWORD=

# ── Compute ───────────────────────────────────────────────────────────────────────────────
# A Mac has no CUDA; 'auto' resolves to CPU (correct, just slower). MPS (Apple Metal) is
# experimental for these models — try it only if you want to.
# EMBED_DEVICE=cpu      # or: mps (experimental)

# ── Non-default data paths (only if you did NOT extract to the home defaults) ──────────────
# INDEX_DIR=/Users/you/neuro-textbook-rag/index
# ASSETS_DIR=/Users/you/neuro-textbook-rag/assets/figures
# CARDS_SOURCE_DB=/Users/you/projects/abns-board-review-lancedb
